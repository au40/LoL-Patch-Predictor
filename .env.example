# Copy this file to ".env" and fill in your keys. Never commit .env.

# Riot API dev key (get one at https://developer.riotgames.com/).
# NOTE: development keys expire every 24 hours — regenerate and paste a fresh one as needed.
RIOT_API_KEY=

# Which Riot regional routing to use for match data.
# americas | asia | europe   (match-v5 uses regional routing, not platform routing)
RIOT_REGION=americas
# Platform routing for league/summoner endpoints: na1 | euw1 | kr | etc.
RIOT_PLATFORM=na1

# Anthropic API key for LLM patch-note extraction (https://console.anthropic.com/)
ANTHROPIC_API_KEY=
